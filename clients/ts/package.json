{
  "name": "@baseworks/foldbase",
  "version": "0.1.0",
  "description": "TypeScript client for foldbase — append, query, and typed projection authoring over HTTP. Zod only; no drizzle, no libsql.",
  "type": "module",
  "publishConfig": { "access": "public" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup",
    "test": "node --import tsx test/smoke.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
